rpc_get_bookmarks() {
	[ ! -f "$BOOKMARK_FILE" ] && echo '{"bookmarks":[]}' && return
	local data
	data=$(cat "$BOOKMARK_FILE" 2>/dev/null)
	[ -z "$data" ] || [ "$data" = "[]" ] && echo '{"bookmarks":[]}' && return
