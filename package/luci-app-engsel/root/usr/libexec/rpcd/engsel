rpc_transfer_balance() {
	local id_token access_token pin receiver amount
	id_token=$(get_cached_token)
	access_token=$(get_cached_access)
	[ -z "$id_token" ] && echo '{"error":"not_logged_in"}' && return
	pin=$(json_gets "$1" '@.pin' 2>/dev/null)
	receiver=$(json_gets "$1" '@.receiver' 2>/dev/null)
	amount=$(json_gets "$1" '@.amount' 2>/dev/null)
	[ -z "$pin" ] || [ -z "$receiver" ] || [ -z "$amount" ] && echo '{"error":"missing_params"}' && return
	receiver=$(normalize_msisdn "$receiver")

	# Generate stage token
	local pin_b64
	pin_b64=$(printf '%s' "$pin" | openssl base64 -A 2>/dev/null)
	local stage_payload
	stage_payload=$(printf '{"pin":"%s","transaction_type":"SHARE_BALANCE","receiver_msisdn":"%s"}' \
		"$pin_b64" "$receiver")
	local stage_url="${BASE_CIAM_URL}/ciam/auth/authorization-token/generate"
	local fp dev_id ts_hdr req_id
	fp=$(gen_ax_fingerprint)
	dev_id=$(gen_ax_device_id)
	ts_hdr=$(get_ts_header)
	req_id=$(gen_uuid)
	local stage_resp
	stage_resp=$(curl -s -m 30 --connect-timeout 15 -X POST "$stage_url" \
		-H "Content-Type: application/json" \
		-H "Authorization: Bearer ${access_token}" \
		-H "User-Agent: ${UA}" \
		-H "Ax-Fingerprint: ${fp}" \
		-H "Ax-Device-Id: ${dev_id}" \
		-H "Ax-Request-At: ${ts_hdr}" \
		-H "Ax-Request-Id: ${req_id}" \
		-d "$stage_payload" 2>/dev/null)
	local auth_code
	auth_code=$(json_gets "$stage_resp" '@.data.authorization_code' 2>/dev/null)
	[ -z "$auth_code" ] && printf '{"error":"stage_token_failed","response":%s}' "$stage_resp" && return

	# Execute balance allotment
	local path="sharings/api/v8/balance/allotment"
	local sig_time
	sig_time=$(($(get_epoch_ms) / 1000))
	local key="${X_API_BASE_SECRET};${sig_time}#ae-hei_9Tee6he+Ik3Gais5=;${receiver};POST;${path};${sig_time}"
	local msg="${access_token};${sig_time};${receiver};${amount};"
	local x_sig
	x_sig=$(printf '%s' "$msg" | openssl dgst -sha512 -hmac "$key" 2>/dev/null | sed 's/.*= //')

	local payload
	payload=$(printf '{"authorization_code":"%s","receiver_msisdn":"%s","amount":%s}' \
		"$auth_code" "$receiver" "$amount")
	api_request "$path" "$payload" "$id_token" "POST" "$x_sig"
}

