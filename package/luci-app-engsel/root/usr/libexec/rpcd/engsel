		local pid
		pid=$(cat "$pid_file")
		kill -0 "$pid" 2>/dev/null && running="true"
	fi
	local last_log=""
	[ -f "$log_file" ] && last_log=$(tail -5 "$log_file" 2>/dev/null | tr '"' "'" | tr '\n' '|')
	printf '{"running":%s,"log":"%s"}' "$running" "$last_log"
}

rpc_autobuy_control() {
	local action
	action=$(json_gets "$1" '@.action' 2>/dev/null)
	case "$action" in
		start)
			engsel --auto-buy &
			echo '{"status":"started"}'
			;;
		stop)
			local pid_file="/var/run/engsel-autobuy.pid"
			if [ -f "$pid_file" ]; then
				kill "$(cat "$pid_file")" 2>/dev/null
				echo '{"status":"stopped"}'
			else
				echo '{"status":"not_running"}'
			fi
			;;
		*)
			echo '{"error":"invalid_action"}'
			;;
	esac
}

rpc_dashboard_segments() {
	local id_token access_token
	id_token=$(get_cached_token)
	access_token=$(get_cached_access)
	[ -z "$id_token" ] && echo '{"error":"not_logged_in"}' && return
	local payload
	payload=$(printf '{"access_token":"%s"}' "$access_token")
	api_request "dashboard/api/v8/segments" "$payload" "$id_token"
}

