rpc_delete_bookmark() {
	local idx
	idx=$(json_gets "$1" '@.index' 2>/dev/null)
	[ -z "$idx" ] && echo '{"error":"missing_index"}' && return
	local data count
	data=$(cat "$BOOKMARK_FILE" 2>/dev/null)
	[ -z "$data" ] && echo '{"error":"empty"}' && return
	# Remove item at index using jsonfilter + rebuild
	count=$(echo "$data" | jsonfilter -l 2>/dev/null || echo 0)
	local result='['
	local i=0 first=1
	while [ "$i" -lt "$count" ]; do
		if [ "$i" -ne "$idx" ]; then
			[ "$first" -eq 0 ] && result="${result},"
			local item
			item=$(echo "$data" | jsonfilter -e "@[$i]" 2>/dev/null)
			result="${result}${item}"
			first=0
		fi
		i=$((i + 1))
	done
	result="${result}]"
	printf '%s' "$result" > "$BOOKMARK_FILE"
	echo '{"status":"ok"}'
}

