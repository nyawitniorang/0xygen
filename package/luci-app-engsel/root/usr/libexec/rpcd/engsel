rpc_delete_account() {
	local idx
	idx=$(json_gets "$1" '@.index' 2>/dev/null)
	[ -z "$idx" ] && echo '{"error":"missing_index"}' && return
	local count
	count=$(jsonfilter -i "$TOKENS_FILE" -l 2>/dev/null || echo 0)
	[ "$idx" -ge "$count" ] && echo '{"error":"invalid_index"}' && return

	# Build new array without the deleted index
	local result='['
	local i=0 first=1
	while [ "$i" -lt "$count" ]; do
		if [ "$i" -ne "$idx" ]; then
			[ "$first" -eq 0 ] && result="${result},"
			local entry
			entry=$(jsonfilter -i "$TOKENS_FILE" -e "@[$i]" 2>/dev/null)
			# Reconstruct entry
			local en es ert esi
			en=$(jsonfilter -i "$TOKENS_FILE" -e "@[$i].number" 2>/dev/null)
			es=$(jsonfilter -i "$TOKENS_FILE" -e "@[$i].subscription_type" 2>/dev/null)
			ert=$(jsonfilter -i "$TOKENS_FILE" -e "@[$i].refresh_token" 2>/dev/null)
			esi=$(jsonfilter -i "$TOKENS_FILE" -e "@[$i].subscriber_id" 2>/dev/null)
			if [ -n "$esi" ]; then
				result="${result}{\"number\":${en},\"subscription_type\":\"${es}\",\"subscriber_id\":\"${esi}\",\"refresh_token\":\"${ert}\"}"
			else
				result="${result}{\"number\":${en},\"subscription_type\":\"${es}\",\"refresh_token\":\"${ert}\"}"
			fi
			first=0
		fi
		i=$((i + 1))
	done
	result="${result}]"
	printf '%s' "$result" > "$TOKENS_FILE"
	echo '{"status":"ok"}'
}

