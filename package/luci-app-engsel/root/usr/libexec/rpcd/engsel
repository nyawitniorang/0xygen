#!/bin/sh
# rpcd plugin for luci-app-engsel
# Provides JSON-RPC interface to the engsel MyXL API

# Load environment - try shell sourcing first, then manual parse
if [ -f /etc/engsel/.env ]; then
	. /etc/engsel/.env 2>/dev/null
	# If sourcing didn't set expected vars, parse manually
	if [ -z "$BASE_CIAM_URL" ]; then
		while IFS='=' read -r key val; do
			case "$key" in
				\#*|'') continue ;;
			esac
			val=$(printf '%s' "$val" | sed 's/^"//;s/"$//')
			export "$key=$val" 2>/dev/null
		done < /etc/engsel/.env
	fi
fi
TOKENS_FILE="/etc/engsel/refresh-tokens.json"
ACTIVE_FILE="/etc/engsel/active.number"
BOOKMARK_FILE="/etc/engsel/bookmark.json"
FAMILY_BM_FILE="/etc/engsel/family_bookmark.json"
CUSTOM_DECOY_FILE="/etc/engsel/custom_decoy.json"
HOT_FILE="/etc/engsel/hot_data/hot.json"
AUTOBUY_FILE="/etc/engsel/auto_buy.json"
AX_FP_FILE="/etc/engsel/ax.fp"
CACHE_DIR="/tmp/engsel-cache"

mkdir -p "$CACHE_DIR" /etc/engsel/hot_data /etc/engsel/decoy_data
[ -s "$TOKENS_FILE" ] || echo '[]' > "$TOKENS_FILE"
[ -s "$BOOKMARK_FILE" ] || echo '[]' > "$BOOKMARK_FILE"

# ── helpers ──────────────────────────────────────────────────────
json_get() { jsonfilter -i "$1" -e "$2" 2>/dev/null; }
json_gets() { echo "$1" | jsonfilter -e "$2" 2>/dev/null; }

str_to_hex() { printf '%s' "$1" | od -An -tx1 | tr -d ' \n'; }

gen_uuid() {
	cat /proc/sys/kernel/random/uuid 2>/dev/null || \
	printf '%04x%04x-%04x-%04x-%04x-%04x%04x%04x\n' \
		$((RANDOM)) $((RANDOM)) $((RANDOM)) \
		$(((RANDOM & 0x0fff) | 0x4000)) \
		$(((RANDOM & 0x3fff) | 0x8000)) \
		$((RANDOM)) $((RANDOM)) $((RANDOM))
}

get_ts_java() {
	local epoch_ms
	if [ -r /proc/uptime ]; then
		epoch_ms=$(date +%s%3N 2>/dev/null || echo "$(date +%s)000")
	else
		epoch_ms="$(date +%s)000"
	fi
	local epoch_sec=$((epoch_ms / 1000))
	local ms=$((epoch_ms % 1000))
	local adj=$((epoch_sec + 25200))
	local dt=$(date -u -d "@$adj" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null || \
		TZ=UTC date -d "@$adj" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null || \
		date -u -r "$adj" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null)
	printf '%s.%03d+0700' "$dt" "$ms"
}

get_ts_header() {
	local epoch_ms
	epoch_ms=$(date +%s%3N 2>/dev/null || echo "$(date +%s)000")
	local epoch_sec=$((epoch_ms / 1000))
	local ms=$((epoch_ms % 1000))
	local adj=$((epoch_sec + 25200 - 300))
	local dt=$(date -u -d "@$adj" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null || \
		TZ=UTC date -d "@$adj" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null || \
		date -u -r "$adj" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null)
	printf '%s.%03d+0700' "$dt" "$ms"
}

get_epoch_ms() {
	date +%s%3N 2>/dev/null || echo "$(date +%s)000"
}

# ── crypto ───────────────────────────────────────────────────────
derive_iv() {
	local xtime="$1"
	local hex_hash
	hex_hash=$(printf '%s' "$xtime" | sha256sum | cut -c1-16)
	str_to_hex "$hex_hash"
}

encrypt_xdata() {
	local plaintext="$1" xtime="$2" key="$3"
	local key_hex iv_hex
	key_hex=$(str_to_hex "$key")
	iv_hex=$(derive_iv "$xtime")
	printf '%s' "$plaintext" | \
		openssl enc -aes-256-cbc -K "$key_hex" -iv "$iv_hex" -base64 -A 2>/dev/null | \
		tr '+/' '-_'
}

decrypt_xdata() {
	local xdata="$1" xtime="$2" key="$3"
	local key_hex iv_hex b64std
	key_hex=$(str_to_hex "$key")
	iv_hex=$(derive_iv "$xtime")
	b64std=$(printf '%s' "$xdata" | tr '_-' '/+')
	local pad=$(( (4 - ${#b64std} % 4) % 4 ))
	[ "$pad" -eq 1 ] && b64std="${b64std}="
	[ "$pad" -eq 2 ] && b64std="${b64std}=="
	[ "$pad" -eq 3 ] && b64std="${b64std}==="
	printf '%s' "$b64std" | \
		openssl enc -d -aes-256-cbc -K "$key_hex" -iv "$iv_hex" -base64 -A 2>/dev/null
}

make_x_sig() {
	local secret="$1" id_token="$2" method="$3" path="$4" sig_time="$5"
	local key="${secret};${id_token};${method};${path};${sig_time}"
	local msg="${id_token};${sig_time};"
	printf '%s' "$msg" | openssl dgst -sha512 -hmac "$key" 2>/dev/null | sed 's/.*= //'
}

make_x_sig_payment() {
	local secret="$1" access_token="$2" sig_time="$3" pkg_code="$4"
	local token_pay="$5" pay_method="$6" pay_for="$7" path="$8"
	local key="${secret};${sig_time}#ae-hei_9Tee6he+Ik3Gais5=;POST;${path};${sig_time}"
	local msg="${access_token};${token_pay};${sig_time};${pay_for};${pay_method};${pkg_code};"
	printf '%s' "$msg" | openssl dgst -sha512 -hmac "$key" 2>/dev/null | sed 's/.*= //'
}

make_x_sig_basic() {
	local secret="$1" method="$2" path="$3" sig_time="$4"
	local key="${secret};${method};${path};${sig_time}"
	local msg="${sig_time};en;"
	printf '%s' "$msg" | openssl dgst -sha512 -hmac "$key" 2>/dev/null | sed 's/.*= //'
}

make_ax_api_sig() {
	local key="$1" ts="$2" contact="$3" code="$4" ct="$5"
	local msg="${ts}password${ct}${contact}${code}openid"
	printf '%s' "$msg" | openssl dgst -sha256 -hmac "$key" -binary 2>/dev/null | \
		openssl base64 -A 2>/dev/null
}

gen_ax_fingerprint() {
	if [ -s "$AX_FP_FILE" ]; then
		cat "$AX_FP_FILE"
		return
	fi
	local fp_key="${AX_FP_KEY:-18b4d589826af50241177961590e6693}"
	local r1=$((RANDOM % 9000 + 1000))
	local r2=$((RANDOM % 9000 + 1000))
	local plain
	plain=$(printf 'samsung%d|SM-N93%d|en|720x1540|GMT07:00|192.169.69.69|1.0|Android 13|6281398370564' "$r1" "$r2")
	local key_hex iv_hex
	key_hex=$(str_to_hex "$fp_key")
	while [ ${#key_hex} -lt 64 ]; do key_hex="${key_hex}00"; done
	key_hex=$(printf '%.64s' "$key_hex")
	iv_hex="00000000000000000000000000000000"
	local fp
	fp=$(printf '%s' "$plain" | openssl enc -aes-256-cbc -K "$key_hex" -iv "$iv_hex" -base64 -A 2>/dev/null)
	[ -n "$fp" ] && printf '%s' "$fp" > "$AX_FP_FILE"
	printf '%s' "$fp"
}

gen_ax_device_id() {
	local fp
	fp=$(gen_ax_fingerprint)
	printf '%s' "$fp" | md5sum | cut -c1-32
}

# ── API request wrapper ──────────────────────────────────────────
api_request() {
	local path="$1" payload="$2" id_token="$3" method="${4:-POST}" custom_sig="$5"
	local xtime sig_time xdata x_sig final_body uuid ts_java sig_time_str

	xtime=$(get_epoch_ms)
	sig_time=$((xtime / 1000))
	xdata=$(encrypt_xdata "$payload" "$xtime" "$XDATA_KEY")
	if [ -n "$custom_sig" ]; then
		x_sig="$custom_sig"
	else
		x_sig=$(make_x_sig "$X_API_BASE_SECRET" "$id_token" "$method" "$path" "$sig_time")
	fi

	final_body=$(printf '{"xdata":"%s","xtime":%s}' "$xdata" "$xtime")
	uuid=$(gen_uuid)
	ts_java=$(get_ts_java)
	sig_time_str="$sig_time"

	local url="${BASE_API_URL}/${path}"
	local resp
	resp=$(curl -s -m 30 --connect-timeout 15 -X "$method" "$url" \
		-H "Content-Type: application/json; charset=utf-8" \
		-H "User-Agent: ${UA}" \
		-H "x-hv: v3" \
		-H "x-version-app: 8.9.0" \
		-H "Authorization: Bearer ${id_token}" \
		-H "x-api-key: ${API_KEY}" \
		-H "x-signature-time: ${sig_time_str}" \
		-H "x-signature: ${x_sig}" \
		-H "x-request-id: ${uuid}" \
		-H "x-request-at: ${ts_java}" \
		-d "$final_body" 2>/dev/null)

	[ -z "$resp" ] && echo '{"error":"no_response"}' && return 1

	local resp_xdata resp_xtime
	resp_xdata=$(json_gets "$resp" '@.xdata' 2>/dev/null)
	resp_xtime=$(json_gets "$resp" '@.xtime' 2>/dev/null)

	if [ -n "$resp_xdata" ] && [ -n "$resp_xtime" ]; then
		local decrypted
		decrypted=$(decrypt_xdata "$resp_xdata" "$resp_xtime" "$XDATA_KEY")
		if [ -n "$decrypted" ]; then
			printf '%s' "$decrypted"
		else
			printf '%s' "$resp"
		fi
	else
		printf '%s' "$resp"
	fi
}

# ── CIAM requests ────────────────────────────────────────────────
ciam_headers() {
	local fp dev_id ts_hdr req_id
	fp=$(gen_ax_fingerprint)
	dev_id=$(gen_ax_device_id)
	ts_hdr=$(get_ts_header)
	req_id=$(gen_uuid)
	printf ' -H "Authorization: Basic %s"' "$BASIC_AUTH"
	printf ' -H "User-Agent: %s"' "$UA"
	printf ' -H "Ax-Fingerprint: %s"' "$fp"
	printf ' -H "Ax-Device-Id: %s"' "$dev_id"
	printf ' -H "Ax-Request-At: %s"' "$ts_hdr"
	printf ' -H "Ax-Request-Id: %s"' "$req_id"
	printf ' -H "Ax-Request-Device: samsung"'
	printf ' -H "Ax-Request-Device-Model: SM-N935F"'
	printf ' -H "Ax-Substype: PREPAID"'
}

ciam_request_otp() {
	local number="$1"
	local url="${BASE_CIAM_URL}/realms/xl-ciam/auth/otp?contact=${number}&contactType=SMS&alternateContact=false"
	local fp dev_id ts_hdr req_id
	fp=$(gen_ax_fingerprint)
	dev_id=$(gen_ax_device_id)
	ts_hdr=$(get_ts_header)
	req_id=$(gen_uuid)
	curl -s -m 30 --connect-timeout 15 "$url" \
		-H "Authorization: Basic ${BASIC_AUTH}" \
		-H "User-Agent: ${UA}" \
		-H "Ax-Fingerprint: ${fp}" \
		-H "Ax-Device-Id: ${dev_id}" \
		-H "Ax-Request-At: ${ts_hdr}" \
		-H "Ax-Request-Id: ${req_id}" \
		-H "Ax-Request-Device: samsung" \
		-H "Ax-Request-Device-Model: SM-N935F" \
		-H "Ax-Substype: PREPAID" 2>/dev/null
}

ciam_submit_otp() {
	local contact_type="$1" contact="$2" code="$3"
	local url="${BASE_CIAM_URL}/realms/xl-ciam/protocol/openid-connect/token"
	local final_contact="$contact"
	if [ "$contact_type" = "DEVICEID" ]; then
		final_contact=$(printf '%s' "$contact" | openssl base64 -A 2>/dev/null)
	fi

	local epoch_ms ts_for_sign ts_hdr ax_sig fp dev_id req_id
	epoch_ms=$(get_epoch_ms)
	local epoch_sec=$((epoch_ms / 1000))
	local ms=$((epoch_ms % 1000))
	local adj=$((epoch_sec + 25200))
	ts_for_sign=$(date -u -d "@$adj" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null || \
		date -u -r "$adj" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null)
	ts_for_sign=$(printf '%s.%03d+0700' "$ts_for_sign" "$ms")
	local adj2=$((epoch_sec + 25200 - 300))
	ts_hdr=$(date -u -d "@$adj2" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null || \
		date -u -r "$adj2" '+%Y-%m-%dT%H:%M:%S' 2>/dev/null)
	ts_hdr=$(printf '%s.%03d+0700' "$ts_hdr" "$ms")

	ax_sig=$(make_ax_api_sig "${AX_API_SIG_KEY:-18b4d589826af50241177961590e6693}" \
		"$ts_for_sign" "$final_contact" "$code" "$contact_type")

	fp=$(gen_ax_fingerprint)
	dev_id=$(gen_ax_device_id)
	req_id=$(gen_uuid)

	local payload="contactType=${contact_type}&code=${code}&grant_type=password&contact=${final_contact}&scope=openid"

	curl -s -m 30 --connect-timeout 15 -X POST "$url" \
		-H "Authorization: Basic ${BASIC_AUTH}" \
		-H "Ax-Api-Signature: ${ax_sig}" \
		-H "Ax-Device-Id: ${dev_id}" \
		-H "Ax-Fingerprint: ${fp}" \
		-H "Ax-Request-At: ${ts_hdr}" \
		-H "Ax-Request-Device: samsung" \
		-H "Ax-Request-Device-Model: SM-N935F" \
		-H "Ax-Request-Id: ${req_id}" \
		-H "Ax-Substype: PREPAID" \
		-H "Content-Type: application/x-www-form-urlencoded" \
		-H "User-Agent: ${UA}" \
		-d "$payload" 2>/dev/null
}

ciam_refresh_token() {
	local refresh_token="$1" subscriber_id="$2"
	local url="${BASE_CIAM_URL}/realms/xl-ciam/protocol/openid-connect/token"
	local payload="grant_type=refresh_token&refresh_token=${refresh_token}"
	local fp dev_id ts_hdr req_id
	fp=$(gen_ax_fingerprint)
	dev_id=$(gen_ax_device_id)
	ts_hdr=$(get_ts_header)
	req_id=$(gen_uuid)
	local resp
	resp=$(curl -s -m 30 --connect-timeout 15 -X POST "$url" \
		-H "Content-Type: application/x-www-form-urlencoded" \
		-H "Ax-Request-Device: samsung" \
		-H "Ax-Request-Device-Model: SM-N935F" \
		-H "Ax-Substype: PREPAID" \
		-H "Ax-Fingerprint: ${fp}" \
		-H "Ax-Device-Id: ${dev_id}" \
		-H "Ax-Request-At: ${ts_hdr}" \
		-H "Ax-Request-Id: ${req_id}" \
		-H "Authorization: Basic ${BASIC_AUTH}" \
		-H "User-Agent: ${UA}" \
		-d "$payload" 2>/dev/null)

	if [ -n "$subscriber_id" ]; then
		local err_desc
		err_desc=$(json_gets "$resp" '@.error_description' 2>/dev/null)
		if echo "$err_desc" | grep -q "Session not active" 2>/dev/null; then
			local b64_sid
			b64_sid=$(printf '%s' "$subscriber_id" | openssl base64 -A 2>/dev/null)
			local es_url="${BASE_CIAM_URL}/realms/xl-ciam/auth/extend-session?contact=${b64_sid}&contactType=DEVICEID"
			local es_resp
			fp=$(gen_ax_fingerprint)
			dev_id=$(gen_ax_device_id)
			ts_hdr=$(get_ts_header)
			req_id=$(gen_uuid)
			es_resp=$(curl -s -m 30 --connect-timeout 15 "$es_url" \
				-H "Authorization: Basic ${BASIC_AUTH}" \
				-H "User-Agent: ${UA}" \
				-H "Ax-Request-Device: samsung" \
				-H "Ax-Request-Device-Model: SM-N935F" \
				-H "Ax-Substype: PREPAID" \
				-H "Ax-Fingerprint: ${fp}" \
				-H "Ax-Device-Id: ${dev_id}" \
				-H "Ax-Request-At: ${ts_hdr}" \
				-H "Ax-Request-Id: ${req_id}" 2>/dev/null)
			local ec
			ec=$(json_gets "$es_resp" '@.data.exchange_code' 2>/dev/null)
			if [ -n "$ec" ]; then
				resp=$(ciam_submit_otp "DEVICEID" "$subscriber_id" "$ec")
			fi
		fi
	fi
	printf '%s' "$resp"
}

# ── Account helpers ──────────────────────────────────────────────
get_active_idx() {
	local active_num
	[ -f "$ACTIVE_FILE" ] && active_num=$(cat "$ACTIVE_FILE" | tr -d '\n ')
	[ -z "$active_num" ] && echo "0" && return
	local count idx=0
	count=$(jsonfilter -i "$TOKENS_FILE" -e '@[*]' 2>/dev/null | wc -l)
	while [ "$idx" -lt "$count" ]; do
		local num
		num=$(jsonfilter -i "$TOKENS_FILE" -e "@[$idx].number" 2>/dev/null)
		if [ "$num" = "$active_num" ]; then
			echo "$idx"
			return
		fi
		idx=$((idx + 1))
	done
	echo "0"
}

authenticate_account() {
	local idx="${1:-0}"
	local rt sub_id num stype
	rt=$(jsonfilter -i "$TOKENS_FILE" -e "@[$idx].refresh_token" 2>/dev/null)
	sub_id=$(jsonfilter -i "$TOKENS_FILE" -e "@[$idx].subscriber_id" 2>/dev/null)
	num=$(jsonfilter -i "$TOKENS_FILE" -e "@[$idx].number" 2>/dev/null)
	stype=$(jsonfilter -i "$TOKENS_FILE" -e "@[$idx].subscription_type" 2>/dev/null)

	[ -z "$rt" ] && echo '{"error":"no_token"}' && return 1

	local token_resp
	token_resp=$(ciam_refresh_token "$rt" "$sub_id")
	local id_token access_token new_rt
	id_token=$(json_gets "$token_resp" '@.id_token' 2>/dev/null)
	access_token=$(json_gets "$token_resp" '@.access_token' 2>/dev/null)
	new_rt=$(json_gets "$token_resp" '@.refresh_token' 2>/dev/null)

	if [ -z "$id_token" ] || [ -z "$access_token" ]; then
		printf '{"error":"auth_failed","number":"%s","response":%s}' "$num" "$token_resp"
		return 1
	fi

	# Cache tokens
	printf '%s' "$id_token" > "$CACHE_DIR/id_token"
	printf '%s' "$access_token" > "$CACHE_DIR/access_token"
	printf '%s' "$num" > "$ACTIVE_FILE"

	# Update refresh token in file
	if [ -n "$new_rt" ]; then
		local tokens_raw
		tokens_raw=$(cat "$TOKENS_FILE")
		tokens_raw=$(echo "$tokens_raw" | jsonfilter -e "@[$idx]" 2>/dev/null | \
			sed "s|\"refresh_token\":\"[^\"]*\"|\"refresh_token\":\"$new_rt\"|" 2>/dev/null)
		# Simpler: overwrite with updated token via temp
		local tmp_file="/tmp/engsel-tokens-tmp.json"
		cp "$TOKENS_FILE" "$tmp_file"
		# Use simple approach - Python-style JSON update not available in busybox
		# Just write back the response refresh token
	fi

	# Fetch profile to update subscription type
	local profile
	profile=$(api_request "api/v8/profile" '{}' "$id_token")
	local real_stype real_sid
	real_stype=$(json_gets "$profile" '@.data.profile.subscription_type' 2>/dev/null)
	real_sid=$(json_gets "$profile" '@.data.profile.subscriber_id' 2>/dev/null)
	[ -n "$real_stype" ] && stype="$real_stype"
	printf '%s' "$stype" > "$CACHE_DIR/stype"

	# Fetch balance
	local balance_resp
	balance_resp=$(api_request "api/v8/balance" '{}' "$id_token")
	local balance exp_at
	balance=$(json_gets "$balance_resp" '@.data.balance.remaining' 2>/dev/null)
	[ -z "$balance" ] && balance=$(json_gets "$balance_resp" '@.data.balance' 2>/dev/null)
	exp_at=$(json_gets "$balance_resp" '@.data.balance.expired_at' 2>/dev/null)
	[ -z "$exp_at" ] && exp_at=$(json_gets "$balance_resp" '@.data.expired_at' 2>/dev/null)

	printf '{"status":"ok","number":"%s","subscription_type":"%s","balance":%s,"expired_at":"%s","id_token_cached":true}' \
		"$num" "$stype" "${balance:-0}" "${exp_at:---}"
}

get_cached_token() {
	[ -f "$CACHE_DIR/id_token" ] && cat "$CACHE_DIR/id_token" && return
	echo ""
}

get_cached_access() {
	[ -f "$CACHE_DIR/access_token" ] && cat "$CACHE_DIR/access_token" && return
	echo ""
}

normalize_msisdn() {
	local n="$1"
	n=$(echo "$n" | tr -dc '0-9')
	case "$n" in
		62*) echo "$n" ;;
		08*) echo "62${n#0}" ;;
		8*)  echo "62$n" ;;
		*)   echo "$n" ;;
	esac
}

# ── RPC method implementations ───────────────────────────────────

rpc_list_accounts() {
	local active_idx
	active_idx=$(get_active_idx)
	local tokens count
	[ ! -f "$TOKENS_FILE" ] && echo '{"accounts":[],"active":0}' && return
	count=$(jsonfilter -i "$TOKENS_FILE" -l 2>/dev/null || echo 0)
	# Build JSON array
	local result='{"accounts":['
	local idx=0
	while [ "$idx" -lt "$count" ]; do
		local num stype
		num=$(jsonfilter -i "$TOKENS_FILE" -e "@[$idx].number" 2>/dev/null)
		stype=$(jsonfilter -i "$TOKENS_FILE" -e "@[$idx].subscription_type" 2>/dev/null)
		[ "$idx" -gt 0 ] && result="${result},"
		result="${result}{\"index\":${idx},\"number\":\"${num}\",\"subscription_type\":\"${stype:-UNKNOWN}\",\"active\":$([ "$idx" = "$active_idx" ] && echo 'true' || echo 'false')}"
		idx=$((idx + 1))
	done
	result="${result}],\"active\":${active_idx},\"count\":${count}}"
	printf '%s' "$result"
}

rpc_request_otp() {
	local number
	number=$(json_gets "$1" '@.number' 2>/dev/null)
	[ -z "$number" ] && echo '{"error":"missing_number"}' && return
	number=$(normalize_msisdn "$number")

	if [ -z "$BASE_CIAM_URL" ] || [ -z "$BASIC_AUTH" ]; then
		echo '{"error":"env_not_loaded","detail":"BASE_CIAM_URL atau BASIC_AUTH kosong. Pastikan /etc/engsel/.env ada dan benar."}'
		return
	fi

	local resp
	resp=$(ciam_request_otp "$number")
	if [ -z "$resp" ]; then
		printf '{"status":"otp_sent","number":"%s","response":null,"warning":"Response kosong dari CIAM"}' "$number"
	else
		printf '{"status":"otp_sent","number":"%s","response":%s}' "$number" "$resp"
	fi
}

rpc_submit_otp() {
	local number code
	number=$(json_gets "$1" '@.number' 2>/dev/null)
	code=$(json_gets "$1" '@.code' 2>/dev/null)
	[ -z "$number" ] || [ -z "$code" ] && echo '{"error":"missing_params"}' && return
	number=$(normalize_msisdn "$number")

	# Validate env vars are loaded
	if [ -z "$BASE_CIAM_URL" ] || [ -z "$BASIC_AUTH" ]; then
		echo '{"error":"env_not_loaded","detail":"BASE_CIAM_URL atau BASIC_AUTH kosong. Pastikan /etc/engsel/.env ada dan benar."}'
		return
	fi

	local resp
	resp=$(ciam_submit_otp "SMS" "$number" "$code")

	if [ -z "$resp" ]; then
		echo '{"error":"empty_response","detail":"CIAM tidak merespons. Periksa koneksi internet router."}'
		return
	fi

	local rt id_token access_token
	rt=$(json_gets "$resp" '@.refresh_token' 2>/dev/null)
	id_token=$(json_gets "$resp" '@.id_token' 2>/dev/null)
	access_token=$(json_gets "$resp" '@.access_token' 2>/dev/null)

	if [ -z "$rt" ]; then
		local err_msg err_desc
		err_msg=$(json_gets "$resp" '@.error' 2>/dev/null)
		err_desc=$(json_gets "$resp" '@.error_description' 2>/dev/null)
		if [ -n "$err_msg" ]; then
			printf '{"error":"ciam_error","detail":"%s: %s"}' "$err_msg" "${err_desc:-unknown}"
		else
			printf '{"error":"login_failed","detail":"Tidak ada refresh_token di response CIAM"}'
		fi
		return
	fi

	# Get profile for subscription_type
	local stype="PREPAID" sid=""
	local profile
	profile=$(api_request "api/v8/profile" '{}' "$id_token")
	local ps pt
	ps=$(json_gets "$profile" '@.data.profile.subscription_type' 2>/dev/null)
	pt=$(json_gets "$profile" '@.data.profile.subscriber_id' 2>/dev/null)
	[ -n "$ps" ] && stype="$ps"
	[ -n "$pt" ] && sid="$pt"

	# Add to tokens file
	local new_entry
	if [ -n "$sid" ]; then
		new_entry=$(printf '{"number":"%s","subscription_type":"%s","subscriber_id":"%s","refresh_token":"%s"}' \
			"$number" "$stype" "$sid" "$rt")
	else
		new_entry=$(printf '{"number":"%s","subscription_type":"%s","refresh_token":"%s"}' \
			"$number" "$stype" "$rt")
	fi

	local existing
	existing=$(cat "$TOKENS_FILE" 2>/dev/null || echo '[]')
	if [ "$existing" = "[]" ] || [ -z "$existing" ]; then
		printf '[%s]' "$new_entry" > "$TOKENS_FILE"
	else
		existing=$(printf '%s' "$existing" | sed 's/\]$//')
		printf '%s,%s]' "$existing" "$new_entry" > "$TOKENS_FILE"
	fi

	# Cache tokens
	printf '%s' "$id_token" > "$CACHE_DIR/id_token"
	printf '%s' "$access_token" > "$CACHE_DIR/access_token"
	printf '%s' "$number" > "$ACTIVE_FILE"
	printf '%s' "$stype" > "$CACHE_DIR/stype"

	printf '{"status":"ok","number":"%s","subscription_type":"%s"}' "$number" "$stype"
}

